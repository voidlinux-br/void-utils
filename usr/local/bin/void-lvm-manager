# Teste se o terminal suporta caracteres gráficos estendidos
sh_ascii_lines() {
	#Isso força o dialog a usar caracteres ASCII básicos para as bordas.
	#if [[ "$LANG" =~ 'UTF-8' ]]; then
	[[ "$(printf '\u250C')" == "┌" ]]
	export NCURSES_NO_UTF8_ACS=$((!$?))
}

sh_setEnvironment() {
	[[ ! -e "$dialogRcFile" ]] && sh_create_dialogrc
	sh_ascii_lines
}

sh_checkroot() {
	((EUID != 0)) && elevate_to_root "$@" || return 0
}

elevate_to_root() {
	msg "This script must be run as root. Elevating privileges..."
	ccabec+='root [elevated]'
	# Tenta usar sudo primeiro (caso esteja configurado)
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	fi
	# Se sudo falhar, tenta su
	if command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	fi
	die "Error: Unable to elevate privileges. Run manually as root."
}

replicate() {
	local char="${1:-#}"
	local nsize="${2:-$(tput cols)}"
	# Gera linha com substituição direta sem forks extras
	printf -v _line "%*s" "$nsize" && printf '%b\n' "${blue}${_line// /$char}${reset}"
}

readconf() {
	local msg="$1"
	local color="${2:-${yellow}}"

	echo -n -e "$color"
	read -r -p "$msg [S/n] :"
	echo -n -e "$reset"
	case "${REPLY^}" in
	[Ss]) return 0 ;;
	"") return 0 ;;
	*) return 1 ;;
	esac
}

debug() {
	# dialog
	whiptail --fb --clear --backtitle "[debug]$0" --title "[debug]$0" --yesno "${*}\n" 0 40
	local result="$?"
	((result)) && exit "$result"
	return "$result"
}

# ===================================================================
# Funções auxiliares
# ===================================================================
run_cmd() {
	local cmd="$*"

	if [[ $DRYRUN -eq 1 ]]; then
		msg "${cyan}[DRY-RUN]${rst} ${cmd}"
	else
		echo -e "  [⚙  ] ${cyan}${cmd}${rst}"
		# Executa o comando, falha se houver erro
		# Redireciona stderr para /dev/null apenas para mkdir -p e ummount -R
		if [[ "$cmd" =~ ^mkdir\ -p ]] || [[ "$cmd" =~ ^umount\ -R ]]; then
			eval "$cmd" &>/dev/null || true
		else
			eval "$cmd" || log_warn_tab "Falha ao executar: $cmd"
		fi
	fi
}

sh_copyright() {
	cat <<-EOF-COPY
		${bold}${cyan}${0##*/} v${_VERSION_}${rst}
		${bold}${cyan}${APPDESC}${rst}
		${bold}${orange}Copyright (c) 2019-2026, ${reset}ChiliLinux Development Team <https://chililinux.com> <https://github.com/chililinux>
		${bold}${orange}Copyright (c) 2019-2026, ${reset}Vilmar Catafesta <vcatafesta@gmail.com>${black}
	EOF-COPY
}

sh_version() {
	cat <<-EOF-VERSION
		  $(sh_copyright)

		        $(gettext 'Este é um software livre: você é livre para alterá-lo e redistribuí-lo.')
		        $(gettext 'O $APP é disponibilizado para você sob a ${yellow}Licença MIT${black}, e')
		        $(gettext 'inclui software de código aberto sob uma variedade de outras licenças.')
		        $(gettext 'Você pode ler instruções sobre como baixar e criar para você mesmo')
		        $(gettext 'o código fonte específico usado para criar esta cópia.')
		        ${red}$(gettext 'Este programa vem com absolutamente NENHUMA garantia.')${reset}
	EOF-VERSION
}

msg() { echo -e "${INFO} ${*}${reset}"; }
log_ok() { echo -e "${TICK} ${*}${reset}"; }
log_err() { echo -e "${CROSS} ${*}${reset}"; }
log_mid() { echo -e "${MID} ${*}${reset}"; }
log_warn() { echo -e "${WARN} ${*}${reset}"; }
msg_tab() { echo -e "  ${INFO} ${*}${reset}"; }
log_ok_tab() { echo -e "  ${TICK} ${*}${reset}"; }
log_err_tab() { echo -e "  ${CROSS} ${*}${reset}"; }
log_mid_tab() { echo -e "  ${MID} ${*}${reset}"; }
log_warn_tab() { echo -e "  ${WARN} ${*}${reset}"; }
die() {
	echo -e "${CROSS} ${red}${*}${reset}"
	exit 1
}

detect_distro() {
	local id=""

	if [[ -r /etc/os-release ]]; then
		# Lê ID=void|arch|debian|... exatamente como a distro declara
		id=$(grep -E '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
	elif [[ -r /usr/lib/os-release ]]; then
		id=$(grep -E '^ID=' /usr/lib/os-release | cut -d= -f2 | tr -d '"')
	else
		echo "unknown"
		return
	fi
	echo "$id"
}

sh_checkDependencies() {
	local DISTRO="$(detect_distro)"
	local aBlock_files=()
	local d
	local pkg
	local errorFound=false
	declare -a missing
	local cmsgNot="$(gettext "Não foi possível encontrar o comando")"
	local cmsgPkg="$(gettext "instalar pacote")"

	for d in "${!PACKAGEDEP[@]}"; do
		if ! command -v "$d" &>/dev/null; then
			pkg="${PACKAGEDEP[$d]}"
			log_err "${red}Error${rst}: ${cmsgNot} $(printf "${cyan}%-15s${rst}\n" "$d") -> ${cmsgPkg} ${cyan}${pkg}${rst}"
			missing+=("${pkg}")
			errorFound=true
		else
			#log_msg "Check: ${cyan}$d"
			:
		fi
	done

	if $errorFound; then
		replicate '='
		echo "${yellow}             $(gettext "IMPOSSÍVEL CONTINUAR")"
		echo "${black}$(gettext "Este script precisa dos comandos listados acima")"
		echo "${black}$(gettext "Instale-os e/ou verifique se eles estão em seu") ${red}\$PATH${reset}"
		replicate '='

		local cmd="${DISTRO_MGR[$DISTRO]}"
		#local pkgs="${DISTRO_PKGS[$DISTRO]}"
		local pkgs="${missing[@]}"

		msg_info "Distro detectada: ${cyan}$DISTRO${rst}"
		if readconf "$(gettext "Instalar dependências base agora?")"; then
			echo -e "${blue}::${rst} $(gettext "Preparando ambiente para") ${green}${DISTRO}${reset}..."
			# Execução dinâmica: $cmd (gerenciador) + $pkgs (lista de pacotes)
			if ! $cmd $pkgs; then
				echo
				echo -e "${red}$(gettext "Erro Crítico:")${rst} $(gettext "A instalação dos pacotes básicos falhou.")"
				exit 1
			fi
			echo
			echo -e "${green}$(gettext "Sucesso:")${reset} $(gettext "Dependências instaladas.")"
		fi
	fi
}

# configure ambiente
set_varcolors
sh_checkroot "$@"

##########################################################################################################

VG="pve"
POOL="data"

RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"
RESET="\e[0m"

confirm() {
	readconf "Confirmar operação?"
	#  echo -e "${yellow}Confirmar operação? (S/n)${rst}"
	#  read -r resp
	#  [[ "$resp" =~ ^[sS]$ ]]
}

pause() {
	echo
	read -rp "${red}Tecle algo para continuar...${rst}"
}

list_vms() {
	replicate '-'
	echo -e "${CYAN}VMs (thin volumes):${RESET}"
	lvs "$VG"
	replicate '-'
}

list_pvs() {
	echo -e "${CYAN}PVS (listar discos físicos):${RESET}"
	pvs
}

list_vgs() {
	echo -e "${CYAN}VGS (listar volume groups):${RESET}"
	vgs
}

list_lvs() {
	echo -e "${CYAN}LVS (listar volumes lógicos):${RESET}"
	lvs -a
}

pool_status() {
	echo -e "${CYAN}Status do thin pool:${RESET}"
	lvs -o+data_percent,metadata_percent
}

add_disk() {
  echo -e "${CYAN}Discos disponíveis:${RESET}"
  lsblk -d -o NAME,SIZE,MODEL

  echo -e "${BLUE}Digite o disco (exemplo: /dev/sdb):${RESET}"
  read -r DISK

  [ -b "$DISK" ] || {
    echo -e "${RED}Disco inválido.${RESET}"
    return 1
  }

  REAL_DISK=$(readlink -f "$DISK")

  PV_LIST=$(pvs --noheadings -o pv_name)

  if echo "$PV_LIST" | while read -r PV; do
       [ "$(readlink -f "$PV")" = "$REAL_DISK" ] && exit 0
     done; then
    replicate '-'
    echo "$PV_LIST" | while read -r PV; do
      REAL=$(readlink -f "$PV")
      grc lsblk -dn -o TYPE,NAME,PATH,SIZE,TRAN,MODEL,LABEL,SERIAL,PTTYPE "$REAL"
    done
    replicate '-'
    echo -e "${GREEN}Disco já é PV. Nada a fazer.${RESET}"
    return 0
  fi

  echo -e "${YELLOW}Adicionar ${DISK} ao VG ${VG}${RESET}"

  if confirm; then
    wipefs -a "$DISK" || return 1
    pvcreate "$DISK" || return 1
    vgextend "$VG" "$DISK" || return 1
    lvextend -l +100%FREE "$VG/$POOL" || return 1
    echo -e "${GREEN}Disco adicionado ao pool.${RESET}"
  else
    echo -e "${RED}Operação cancelada.${RESET}"
  fi
}

remove_disk() {
	echo -e "${CYAN}PVs atuais:${RESET}"
	pvs

	echo -e "${BLUE}Digite o disco para remover (exemplo: /dev/sdb):${RESET}"
	read -r DISK

	echo -e "${YELLOW}Remover ${DISK} do VG ${VG}${RESET}"

	if confirm; then
		vgreduce "$VG" "$DISK"
		pvremove "$DISK"
		echo -e "${GREEN}Disco removido.${RESET}"
	else
		echo -e "${RED}Operação cancelada.${RESET}"
	fi
}

create_vm() {
	echo -e "${CYAN}Exemplo: VMID=100 cria vm-100-disk-0${RESET}"
	echo -e "${BLUE}ID da VM (ex: 100):${RESET}"
	read -r VMID

	echo -e "${BLUE}Tamanho do disco (ex: 50G):${RESET}"
	read -r SIZE

	NAME="${VMID}"
	echo -e "${YELLOW}Criar volume ${NAME} com ${SIZE}${RESET}"

	if confirm; then
		lvcreate -V "$SIZE" -T "$VG/$POOL" -n "$NAME"
		echo -e "${GREEN}VM criada com sucesso.${RESET}"
		list_vms
	else
		echo -e "${RED}Operação cancelada.${RESET}"
	fi
}

remove_vm() {
	echo -e "${CYAN}VMs existentes:${RESET}"
	lvs "$VG"

	echo -e "${BLUE}Digite o nome da VM (ex: vm-100-disk-0):${RESET}"
	read -r NAME

	echo -e "${YELLOW}Remover ${NAME}${RESET}"

	if confirm; then
		lvremove "$VG/$NAME"
		echo -e "${GREEN}VM removida.${RESET}"
	else
		echo -e "${RED}Operação cancelada.${RESET}"
	fi
}

while true; do
	clear
	replicate '-'
	echo -e "${CYAN}========= $APP - GERENCIADOR LVM THIN =========${RESET}"
	replicate '-'
	echo -e "${GREEN}1${RESET}  - Listar VMs (thin volumes)"
	echo -e "${GREEN}2${RESET}  - PVS (listar discos físicos)"
	echo -e "${GREEN}3${RESET}  - VGS (listar volume groups)"
	echo -e "${GREEN}4${RESET}  - LVS (listar volumes lógicos)"
	echo -e "${GREEN}5${RESET}  - Thin Pool (uso do pool)"
	echo
	echo -e "${GREEN}6${RESET}  - Acrescentar disco (pvcreate + vgextend)"
	echo -e "${GREEN}7${RESET}  - Remover disco (vgreduce + pvremove)"
	echo
	echo -e "${GREEN}8${RESET}  - Criar VM (lvcreate thin)"
	echo -e "${GREEN}9${RESET}  - Remover VM (lvremove)"
	echo
	echo -e "${RED}0${RESET}  - Sair"
	echo
	read -rp "Escolha: " opt

	case "$opt" in
	1)
		list_vms
		pause
		;;
	2)
		list_pvs
		pause
		;;
	3)
		list_vgs
		pause
		;;
	4)
		list_lvs
		pause
		;;
	5)
		pool_status
		pause
		;;
	6)
		add_disk
		pause
		;;
	7)
		remove_disk
		pause
		;;
	8)
		create_vm
		pause
		;;
	9)
		remove_vm
		pause
		;;
	0) exit ;;
	*)
		echo -e "${RED}Opção inválida${RESET}"
		pause
		;;
	esac

done
