# Teste se o terminal suporta caracteres gráficos estendidos
sh_ascii_lines() {
	#Isso força o dialog a usar caracteres ASCII básicos para as bordas.
	#if [[ "$LANG" =~ 'UTF-8' ]]; then
	[[ "$(printf '\u250C')" == "┌" ]]
	export NCURSES_NO_UTF8_ACS=$((!$?))
}

sh_setEnvironment() {
	[[ ! -e "$dialogRcFile" ]] && sh_create_dialogrc
	sh_ascii_lines
}

sh_checkroot() {
	((EUID != 0)) && elevate_to_root "$@" || return 0
}

elevate_to_root() {
	msg "This script must be run as root. Elevating privileges..."
	ccabec+='root [elevated]'
	# Tenta usar sudo primeiro (caso esteja configurado)
	if command -v sudo >/dev/null 2>&1; then
		exec sudo bash "$0" "$@"
	fi
	# Se sudo falhar, tenta su
	if command -v su >/dev/null 2>&1; then
		exec su -c "$0 $*"
	fi
	die "Error: Unable to elevate privileges. Run manually as root."
}

replicate() {
	local char="${1:-#}"
	local nsize="${2:-$(tput cols)}"
	# Gera linha com substituição direta sem forks extras
	printf -v _line "%*s" "$nsize" && printf '%b\n' "${blue}${_line// /$char}${reset}"
}

readconf() {
	local msg="$1"
	local color="${2:-${yellow}}"

	echo -n -e "$color"
	if [[ $LC_DEFAULT -eq 0 ]]; then
		read -r -p "$msg [N/s] :"
	else
		read -r -p "$msg [N/y] :"
	fi
	echo -n -e "$reset"
	case "${REPLY^}" in
	[SY]) return 0 ;;
	"") return 1 ;;
	*) return 1 ;;
	esac
}

debug() {
	# dialog
	whiptail --fb --clear --backtitle "[debug]$0" --title "[debug]$0" --yesno "${*}\n" 0 40
	local result="$?"
	((result)) && exit "$result"
	return "$result"
}

# ===================================================================
# Funções auxiliares
# ===================================================================
run_cmd() {
	local cmd="$*"

	if [[ $DRYRUN -eq 1 ]]; then
		msg "${cyan}[DRY-RUN]${rst} ${cmd}"
	else
		echo -e "  [⚙  ] ${cyan}${cmd}${rst}"
		# Executa o comando, falha se houver erro
		# Redireciona stderr para /dev/null apenas para mkdir -p e ummount -R
		if [[ "$cmd" =~ ^mkdir\ -p ]] || [[ "$cmd" =~ ^umount\ -R ]]; then
			eval "$cmd" &>/dev/null || true
		else
			eval "$cmd" || log_warn_tab "Falha ao executar: $cmd"
		fi
	fi
}

sh_copyright() {
	cat <<-EOF-COPY
		${bold}${cyan}${0##*/} v${_VERSION_}${rst}
		${bold}${cyan}${APPDESC}${rst}
		${bold}${orange}Copyright (c) 2019-2026, ${reset}ChiliLinux Development Team <https://chililinux.com> <https://github.com/chililinux>
		${bold}${orange}Copyright (c) 2019-2026, ${reset}VoidBR Development Team <https://voidbr.org> <https://github.com/voidlinuxbr>
		${bold}${orange}Copyright (c) 2019-2026, ${reset}Vilmar Catafesta <vcatafesta@gmail.com>${black}
	EOF-COPY
}

sh_version() {
	cat <<-EOF-VERSION
		  $(sh_copyright)

		        $(gettext "Este é um software livre: você é livre para alterá-lo e redistribuí-lo.")
		        $(gettext "O $APP é disponibilizado para você sob a ${yellow}Licença MIT${black}, e")
		        $(gettext "inclui software de código aberto sob uma variedade de outras licenças.")
		        $(gettext "Você pode ler instruções sobre como baixar e criar para você mesmo")
		        $(gettext "o código fonte específico usado para criar esta cópia.")
		        ${red}$(gettext "Este programa vem com absolutamente NENHUMA garantia.")${reset}
	EOF-VERSION
}

msg() { echo -e "${INFO} ${*}${reset}"; }
log_ok() { echo -e "${TICK} ${*}${reset}"; }
log_err() { echo -e "${CROSS} ${*}${reset}"; }
log_mid() { echo -e "${MID} ${*}${reset}"; }
log_warn() { echo -e "${WARN} ${*}${reset}"; }
msg_tab() { echo -e "  ${INFO} ${*}${reset}"; }
log_ok_tab() { echo -e "  ${TICK} ${*}${reset}"; }
log_err_tab() { echo -e "  ${CROSS} ${*}${reset}"; }
log_mid_tab() { echo -e "  ${MID} ${*}${reset}"; }
log_warn_tab() { echo -e "  ${WARN} ${*}${reset}"; }
die() {
	echo -e "${CROSS} ${red}${*}${reset}"
	exit 1
}

detect_distro() {
	local id=""

	if [[ -r /etc/os-release ]]; then
		# Lê ID=void|arch|debian|... exatamente como a distro declara
		id=$(grep -E '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
	elif [[ -r /usr/lib/os-release ]]; then
		id=$(grep -E '^ID=' /usr/lib/os-release | cut -d= -f2 | tr -d '"')
	else
		echo "unknown"
		return
	fi
	echo "$id"
}

sh_checkDependencies() {
	local aBlock_files=()
	local d
	local pkg
	local errorFound=false
	declare -a missing
	local DISTRO
	local cmsgNot
	local cmsgPkg
	DISTRO="$(detect_distro)"
	cmsgNot="$(gettext "Não foi possível encontrar o comando")"
	cmsgPkg="$(gettext "instalar pacote")"

	for d in "${!PACKAGEDEP[@]}"; do
		if ! command -v "$d" &>/dev/null; then
			pkg="${PACKAGEDEP[$d]}"
			log_err "${red}Error${rst}: ${cmsgNot} $(printf "${cyan}%-15s${rst}\n" "$d") -> ${cmsgPkg} ${cyan}${pkg}${rst}"
			missing+=("${pkg}")
			errorFound=true
		else
			#log_msg "Check: ${cyan}$d"
			:
		fi
	done

	if $errorFound; then
		replicate '='
		echo "${yellow}             $(gettext "IMPOSSÍVEL CONTINUAR")"
		echo "${black}$(gettext "Este script precisa dos comandos listados acima")"
		echo "${black}$(gettext "Instale-os e/ou verifique se eles estão em seu") ${red}\$PATH${reset}"
		replicate '='

		local cmd="${DISTRO_MGR[$DISTRO]}"
		#local pkgs="${DISTRO_PKGS[$DISTRO]}"
		local pkgs="${missing[@]}"

		msg_info "Distro detectada: ${cyan}$DISTRO${rst}"
		if readconf "$(gettext "Instalar dependências base agora?")"; then
			echo -e "${blue}::${rst} $(gettext "Preparando ambiente para") ${green}${DISTRO}${reset}..."
			# Execução dinâmica: $cmd (gerenciador) + $pkgs (lista de pacotes)
			if ! $cmd "$pkgs"; then
				echo
				echo -e "${red}$(gettext "Erro Crítico:")${rst} $(gettext "A instalação dos pacotes básicos falhou.")"
				exit 1
			fi
			echo
			echo -e "${green}$(gettext "Sucesso:")${reset} $(gettext "Dependências instaladas.")"
		fi
	fi
}

# configure ambiente
set_varcolors
sh_checkroot "$@"

##########################################################################################################

warn() { printf "${yellow}==> AVISO:${reset} %s\n" "$1"; }
err() { printf "${red}==> ERRO:${reset} %s\n" "$1"; }
changed=false

detect_init() {
	init_system=$(ps -p 1 -o comm=)
	case "$init_system" in
		systemd) init="systemd" ;;
		runit) init="runit" ;;
		*) init="unknown" ;;
	esac
	msg "Init detectado: $init"
}

check_root() {
	if [[ $EUID -ne 0 ]]; then
		err "Execute como root."
		exit 1
	fi
}

cleanup_old_voidbr_runit() {
	if [[ "$init" != "runit" ]]; then
		return
	fi
	msg "Removendo configuração antiga VoidBR..."
	rm -f /etc/runit/core-services/10-zram.sh
	rm -f /etc/runit/core-services/10-voidbr-zram.sh
}

cleanup_old_chili_systemd() {
  if [[ "$init" != "systemd" ]]; then
    return
  fi

  msg "Verificando configuração antiga Chili (systemd)..."

  for svc in chili-thp chili-bfq chili-zram; do
    file="/etc/systemd/system/${svc}.service"

    if [ -f "$file" ]; then
      if grep -q "/usr/local/sbin/${svc}" "$file"; then
        msg_warn "Removendo serviço antigo $svc"
        systemctl disable "$svc" 2>/dev/null
        rm -f "$file"
        changed=true
      fi
    fi
  done

  for f in \
    /usr/local/sbin/chili-thp \
    /usr/local/sbin/chili-bfq \
    /usr/local/sbin/chili-zram; do
    if [ -f "$f" ]; then
      msg_warn "Removendo script antigo $(basename "$f")"
      rm -f "$f"
      changed=true
    fi
  done

  if $changed; then
    systemctl daemon-reload
  fi
}

detect_ram() {
	ram_gb=$(awk '/MemTotal/ {printf "%.0f", $2/1024/1024}' /proc/meminfo)
	msg "RAM detectada: ${ram_gb} GB"
}

calculate_swap() {
	if ((ram_gb <= 2)); then
		swap_gb=6
	elif ((ram_gb <= 4)); then
		swap_gb=8
	elif ((ram_gb <= 8)); then
		swap_gb=12
	else
		swap_gb=$ram_gb
	fi
	msg "Swap recomendada: ${swap_gb} GB"
}

remove_zram() {
	if grep -q "^zram" /proc/modules; then
		msg "Removendo zram..."
		if command -v zramctl >/dev/null; then
			for dev in $(zramctl -n -o NAME 2>/dev/null); do
				swapoff "$dev" 2>/dev/null
			done
		fi
		modprobe -r zram 2>/dev/null
		changed=true
	fi
	mkdir -p /etc/modprobe.d
	if ! grep -q "^blacklist zram" /etc/modprobe.d/disable-zram.conf 2>/dev/null; then
		echo "blacklist zram" >/etc/modprobe.d/disable-zram.conf
		changed=true
	fi
}

create_swapfile() {
	swapoff /swapfile 2>/dev/null
	rm -f /swapfile
	msg "Criando swapfile ${swap_gb}G..."
	if ! fallocate -l ${swap_gb}G /swapfile 2>/dev/null; then
		dd if=/dev/zero of=/swapfile bs=1M count=$((swap_gb * 1024))
	fi
	chmod 600 /swapfile
	mkswap /swapfile
	changed=true
}

configure_swapfile() {
	desired_size=$((swap_gb * 1024 * 1024 * 1024))
	if [ -f /swapfile ]; then
		current_size=$(stat -c%s /swapfile)
		if [ "$current_size" -ne "$desired_size" ]; then
			current_gb=$((current_size / 1024 / 1024 / 1024))
			warn "Swap atual: ${current_gb}G"
			warn "Swap recomendado: ${swap_gb}G"
			create_swapfile
		else
			msg "Swapfile já está no tamanho correto."
		fi
	else
		create_swapfile
	fi
	if ! grep -qE '^[[:space:]]*/swapfile[[:space:]]' /etc/fstab; then
		echo "/swapfile none swap defaults,pri=20 0 0" >> /etc/fstab
		changed=true
	fi
}

configure_sysctl() {
	if [[ "$init" == "systemd" ]]; then
		file=/etc/sysctl.d/99-chili-memory-tuning.conf
	else
		file=/etc/sysctl.d/99-voidbr-memory-tuning.conf
	fi
	msg "Configurando parâmetros de memória..."
	if [ ! -f "$file" ]; then
		cat <<EOF > "$file"
vm.swappiness=180
vm.vfs_cache_pressure=200
vm.page-cluster=0
vm.dirty_background_ratio=3
vm.dirty_ratio=10
vm.dirty_expire_centisecs=3000
vm.dirty_writeback_centisecs=500
EOF
		sysctl --system >/dev/null
		changed=true
	else
		msg_tab "Sysctl já configurado."
	fi
}

configure_zswap() {
	msg "Configurando zswap..."
	if [ -f /etc/default/grub ]; then
		if ! grep -q "zswap.enabled" /etc/default/grub; then
			sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/GRUB_CMDLINE_LINUX_DEFAULT="zswap.enabled=1 zswap.max_pool_percent=25 /' /etc/default/grub
			if command -v update-grub >/dev/null; then
				update-grub
			elif command -v grub-mkconfig >/dev/null; then
				grub-mkconfig -o /boot/grub/grub.cfg
			fi
			changed=true
		else
			msg_tab "zswap já configurado."
		fi
	else
		warn "GRUB não encontrado. Ative zswap manualmente."
	fi
}

configure_thp() {
  msg "Configurando THP"
	if [[ "$init" == "runit" ]]; then
		file=/etc/runit/core-services/05-voidbr-thp.sh
		if [ ! -f "$file" ]; then
			cat <<'EOF' >"$file"
#!/bin/sh
echo never > /sys/kernel/mm/transparent_hugepage/enabled
EOF
			chmod +x "$file"
			changed=true
		else
			msg_tab "THP já configurado."
		fi
	elif [[ "$init" == "systemd" ]]; then
		file=/etc/systemd/system/chili-thp.service
		if [ ! -f "$file" ]; then
			cat <<'EOF' >"$file"
[Unit]
Description=Disable Transparent Huge Pages (Chili)
[Service]
Type=oneshot
ExecStart=/bin/sh -c 'echo never > /sys/kernel/mm/transparent_hugepage/enabled'
RemainAfterExit=yes
[Install]
WantedBy=multi-user.target
EOF
			systemctl daemon-reload
			systemctl enable chili-thp
			changed=true
		else
			msg_tab "THP já configurado."
		fi
	fi
}

detect_disk() {
	root_partition=$(findmnt -n -o SOURCE /)
	disk=$(lsblk -no PKNAME "$root_partition" | tail -n1)
	disk=$(echo "$disk" | sed 's/p[0-9]\+$//; s/[0-9]\+$//')
	if [[ -z "$disk" ]]; then
		disk=$(lsblk -ndo NAME,TYPE | awk '$2=="disk"{print $1;exit}')
	fi
	is_rotational=$(cat /sys/block/"$disk"/queue/rotational 2>/dev/null)
	if [[ "$is_rotational" == "0" ]]; then
		type="SSD"
		scheduler="mq-deadline"
	else
		type="HDD"
		scheduler="bfq"
	fi
	msg "$type detectado ($disk)"
}

configure_scheduler() {
	if [[ "$init" == "runit" ]]; then
		file=/etc/runit/core-services/03-voidbr-scheduler.sh
		if [ ! -f "$file" ]; then
			cat <<EOF >"$file"
#!/bin/sh
for d in /sys/block/*; do
	[ -e "\$d/queue/scheduler" ] && echo "$scheduler" > "\$d/queue/scheduler" 2>/dev/null
done
EOF
			chmod +x "$file"
			changed=true
		else
			msg "Scheduler já configurado."
		fi
	elif [[ "$init" == "systemd" ]]; then
		file=/etc/systemd/system/chili-bfq.service
		if [ ! -f "$file" ]; then
			cat <<EOF >"$file"
[Unit]
Description=Set BFQ IO Scheduler (Chili)
[Service]
Type=oneshot
ExecStart=/bin/sh -c 'for d in /sys/block/sd*; do echo bfq > "\$d/queue/scheduler" 2>/dev/null; done'
RemainAfterExit=yes
[Install]
WantedBy=multi-user.target
EOF
			systemctl daemon-reload
			systemctl enable chili-bfq
			changed=true
		else
			msg "Scheduler já configurado."
		fi
	fi
}

enable_swap() {
	if ! swapon --show=NAME | grep -q "^/swapfile$"; then
		swapon /swapfile
	fi
}

summary() {
	replicate '-'
	echo "${blue}Resumo do sistema${rst}"
	replicate '-'
	msg_tab "RAM             : ${ram_gb} GB"
	msg_tab "Swap configurada: ${swap_gb} GB"
	msg_tab "$(swapon --show)"
	msg_tab "$(sysctl vm.swappiness)"
	echo
	if $changed; then
		echo -e "${yellow}Alterações efetuadas. Reinicie o sistema!${reset}"
	else
		msg "${green}Nenhuma alteração foi necessária.${rst}"
	fi
}

main() {
	check_root
	detect_init
	cleanup_old_voidbr_runit
	cleanup_old_chili_systemd
	detect_ram
	calculate_swap
	remove_zram
	configure_swapfile
	configure_sysctl
	configure_zswap
	configure_thp
	echo $changed
	detect_disk
	configure_scheduler
	enable_swap
	summary
}

main
